<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER"
      spacing="12"
      fillWidth="true"
      stylesheets="@css/Concesionario.css"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.concesionario.Controllers.LoginController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Login" styleClass="label-titulo">
        <font>
            <Font name="SimSun" size="45.0" />
        </font>
    </Label>

    <TextField fx:id="txtUser"
               promptText="Usuario"
               maxWidth="Infinity" />

    <PasswordField fx:id="txtPassword"
                   promptText="Contraseña"
                   maxWidth="Infinity" />

    <Button text="Entrar"
            onAction="#onLoginButtonClick"
            maxWidth="Infinity" />

    <Button text="Salir"
            onAction="#onSalirButtonClick"
            maxWidth="Infinity" />

    <Label fx:id="lblError"
           styleClass="label-error" />

</VBox>
